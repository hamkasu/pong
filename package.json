{
  "name": "pong-levels-online",
  "version": "2.0.0",
  "description": "Online multiplayer Pong game with 7 progressive levels, user accounts, and leaderboards",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrations/setup.js",
    "db:stats": "node scripts/db-maintenance.js",
    "db:reset": "node scripts/db-maintenance.js",
    "deploy": "bash scripts/deploy.sh",
    "docker:build": "docker build -t pong-levels-online .",
    "docker:run": "docker-compose up",
    "docker:down": "docker-compose down",
    "test:connection": "node -e \"console.log('Testing database connection...'); require('./migrations/setup.js')\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "pg": "^8.11.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "pong",
    "game",
    "multiplayer",
    "online",
    "arcade",
    "retro",
    "leaderboard",
    "realtime",
    "websocket",
    "postgresql"
  ],
  "author": "Your Name",
  "license": "MIT"
}